[Unit]
Description=Rusty SOCKS5 Proxy Server
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/opt/rusty_socks_proxy/rusty_socks_proxy
Restart=always
RestartSec=5
User=root
Group=root
Environment="SOCKS5_PORT=1080"
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rusty_socks_proxy

# Security settings
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/rusty_socks_proxy

[Install]
WantedBy=multi-user.target

